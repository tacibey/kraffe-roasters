---
// src/layouts/MainLayout.astro

import Meta from "@components/Meta.astro";
import Navbar from "@components/sections/navbar&footer/Navbar.astro";
import FooterSection from "@components/sections/navbar&footer/FooterSection.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import { SITE } from "@data/constants";
import "@styles/global.css";
import { getRelativeLocaleUrl } from "astro:i18n";
import { ORGANIZATION_SCHEMA } from "../data_files/site_meta.ts";

const { title = SITE.title, meta, structuredData, lang = "en" } = Astro.props;

interface Props {
  title?: string;
  meta?: string;
  structuredData?: object;
  lang?: string;
}

const currentLang = Astro.currentLocale || 'en';
const contactUrl = getRelativeLocaleUrl(currentLang, 'contact');
const buttonText = currentLang === 'fr' ? 'Obtenir une offre' : 'Get Offer';
---

<html lang={lang} class="dark scrollbar-hide lenis lenis-smooth scroll-pt-16">
  <head>
    <!-- START: Google Consent Mode & GTM -->
    <script is:inline>
      // dataLayer ve gtag fonksiyonunu tanımla.
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      // Kullanıcı seçim yapmadan önce varsayılan izin durumunu 'reddedildi' olarak ayarla.
      // Bu, GTM script'inden ÖNCE gelmelidir.
      gtag('consent', 'default', {
        'ad_storage': 'denied',
        'ad_user_data': 'denied',
        'ad_personalization': 'denied',
        'analytics_storage': 'denied',
        'wait_for_update': 500
      });
    </script>
    
    <!-- Google Tag Manager (Meta Ajansı) -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-WGJTKJSG');</script>
    <!-- End Google Tag Manager (Meta Ajansı) -->

    <!-- Google Tag Manager (Google Reklam Ajansı) -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-KFH3PNCV');</script>
    <!-- End Google Tag Manager (Google Reklam Ajansı) -->

    <!-- HACK: Yeni Cookie Banner CSS (CDN) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orestbida/cookieconsent@v3.0.0/dist/cookieconsent.css">

    {/* Orijinal Meta ve Başlık Bilgileriniz */}
    <Meta meta={meta} structuredData={structuredData} />
    <title>{title}</title>
    
    <!-- Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(ORGANIZATION_SCHEMA)} />

    <style is:inline>
      h1.block { display: block; }
      h1.text-balance { text-wrap: balance; }
      h1.text-3xl { font-size: 1.875rem; line-height: 2.25rem; }
      h1.font-bold { font-weight: 700; }
      h1.tracking-tight { letter-spacing: -0.025em; }

      html.scroll-pt-16 { scroll-padding-top: 4rem; }
      html.scrollbar-hide::-webkit-scrollbar { display: none; }
      html.scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
    <script>
      import "@scripts/lenisSmoothScroll.js";
    </script>
  </head>
  <body
    class="bg-neutral-200 selection:bg-yellow-400 selection:text-neutral-700 dark:bg-neutral-800"
  >
    <!-- Google Tag Manager (noscript) (Meta Ajansı) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WGJTKJSG"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) (Meta Ajansı) -->

    <!-- Google Tag Manager (noscript) (Google Reklam Ajansı) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KFH3PNCV"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) (Google Reklam Ajansı) -->
    
    <div class="mx-auto max-w-(--breakpoint-2xl) px-4 sm:px-6 lg:px-8">
      <Navbar />
      <main>
        <slot />
      </main>
    </div>

    <AnnouncementBanner
      btnId="floating-offer-button"
      btnTitle={buttonText}
      url={contactUrl}
    />

    <FooterSection />

    <script>
      import "preline/preline.js";
    </script>
    <style>
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }
      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>

    <!-- HACK: Cookie Consent Script & Configuration -->
    <script type="module">
      import * as CookieConsent from "https://cdn.jsdelivr.net/gh/orestbida/cookieconsent@v3.0.0/dist/cookieconsent.esm.js";

      // GTM Consent Update Fonksiyonu
      function updateGtmConsent(categories) {
        const consentState = {
          'ad_storage': categories.includes('advertising') ? 'granted' : 'denied',
          'ad_user_data': categories.includes('advertising') ? 'granted' : 'denied',
          'ad_personalization': categories.includes('advertising') ? 'granted' : 'denied',
          'analytics_storage': categories.includes('analytics') ? 'granted' : 'denied'
        };

        // GTM'e durumu bildir
        if (typeof window.gtag === 'function') {
            window.gtag('consent', 'update', consentState);
        }
        
        // Event fırlat (GTM trigger için)
        window.dataLayer.push({
          'event': 'consent_update',
          'consent_status': consentState
        });
      }

      CookieConsent.run({
        guiOptions: {
          consentModal: {
            layout: 'box',
            position: 'bottom left',
            equalWeightButtons: false,
            flipButtons: false
          },
          preferencesModal: {
            layout: 'box',
            position: 'right',
            equalWeightButtons: false,
            flipButtons: false
          }
        },
        categories: {
          necessary: {
            readOnly: true,
            enabled: true
          },
          analytics: {
            // HACK: Varsayılan olarak SEÇİLİ gelsin
            enabled: true,
            autoClear: false
          },
          advertising: {
            // HACK: Varsayılan olarak SEÇİLİ gelsin
            enabled: true,
            autoClear: false
          }
        },
        language: {
          default: 'en',
          translations: {
            en: {
              consentModal: {
                title: 'We value your privacy 🍪',
                description: 'We use cookies to enhance your experience, provide personalized content, and analyze our traffic.',
                acceptAllBtn: 'Accept All', // HACK: Sadece bu ve yönet butonu var. Reddet yok.
                showPreferencesBtn: 'Manage Preferences',
                footer: '<a href="/cookie-policy">Cookie Policy</a>'
              },
              preferencesModal: {
                title: 'Cookie Preferences',
                acceptAllBtn: 'Accept All',
                acceptNecessaryBtn: 'Reject All', // Bu buton ayarlarda görünür ama ana ekranda görünmez
                savePreferencesBtn: 'Save Preferences',
                closeIconLabel: 'Close',
                sections: [
                  {
                    title: 'Strictly Necessary',
                    description: 'These cookies are essential for the proper functioning of the website.',
                    linkedCategory: 'necessary'
                  },
                  {
                    title: 'Performance & Analytics',
                    description: 'These cookies allow us to count visits and traffic sources so we can measure and improve the performance of our site.',
                    linkedCategory: 'analytics'
                  },
                  {
                    title: 'Advertisement & Targeting',
                    description: 'These cookies may be set through our site by our advertising partners to build a profile of your interests.',
                    linkedCategory: 'advertising'
                  }
                ]
              }
            }
          }
        },
        onConsent: ({ cookie }) => {
          updateGtmConsent(cookie.categories);
        },
        onChange: ({ cookie }) => {
          updateGtmConsent(cookie.categories);
        }
      });
    </script>

    <!-- HACK: Kraffe Roasters Özel Tasarım CSS'i -->
    <style is:global>
      :root {
        --cc-bg: #1a1a1a; /* Koyu arka plan */
        --cc-text: #e5e5e5;
        --cc-btn-primary-bg: #F25F29; /* Kraffe Turuncusu */
        --cc-btn-primary-text: #ffffff;
        --cc-btn-primary-hover-bg: #d14d1f;
        --cc-btn-secondary-bg: #333333;
        --cc-btn-secondary-text: #ffffff;
        --cc-btn-secondary-hover-bg: #444444;
        --cc-toggle-on-bg: #F25F29; /* Toggle açık rengi */
        --cc-font-family: inherit;
      }

      /* Ana Banner'da "Gerekli" veya "Reddet" butonunu gizle */
      #cc-main .cm__btn[data-role="necessary"] {
        display: none !important;
      }

      /* Butonları biraz daha köşeli yap (Kraffe tarzı) */
      #cc-main .cm__btn {
        border-radius: 4px;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
      }

      /* Kabul et butonu parlasın */
      #cc-main .cm__btn[data-role="all"] {
        background-color: var(--cc-btn-primary-bg);
        color: var(--cc-btn-primary-text);
      }
      
      /* Link rengi */
      #cc-main a {
        color: #F25F29;
      }
/* --- DÜZELTME BAŞLANGICI --- */
      
      /* Başlıkların Rengi (We value your privacy & Preferences) */
      #cc-main .cm__title,
      #cc-main .pm__title {
        color: #f3f4f6 !important; /* Beyaza çok yakın açık gri */
      }

      /* Gri Butonların (Manage Preferences / Reject) Yazı Rengi */
      #cc-main .cm__btn--secondary, 
      #cc-main .pm__btn--secondary {
        color: #f3f4f6 !important; /* Buton içi yazı rengi */
        border: 1px solid #444 !important; /* Hafif bir çerçeve ekledim ki buton olduğu belli olsun */
      }

      /* --- DÜZELTME SONU --- */
    </style>

  </body>
</html>
