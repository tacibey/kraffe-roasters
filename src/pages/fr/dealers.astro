---
// src/pages/fr/dealers.astro

// --- DÜZELTME BAŞLANGICI: Kısayol (@) yerine göreceli yollar kullanıldı ---
import MainLayout from "../../layouts/MainLayout.astro";
import MainSection from "../../components/ui/blocks/MainSection.astro";
import DealerCard from "../../components/ui/cards/DealerCard.astro";
// --- DÜZELTME SONU ---

const dealers = [
  {
    name: "Abdullah Ali Al-Bowait",
    company: "Burj Pisa Trading Est.",
    phone: "+966 54 596 5639",
    email: "sqa2022@gmail.com",
    country: "Arabie Saoudite",
  },
];

const meta = {
  title: "Revendeurs Kraffe Roasters | Partenaires Autorisés",
  description: "Trouvez les revendeurs et partenaires agréés de Kraffe Roasters dans votre région. Contactez nos distributeurs officiels pour les ventes, le support et les services.",
};
---

<MainLayout meta={meta} lang="fr">
  <MainSection
    title="Nos Revendeurs Agréés"
    subTitle="Contactez nos partenaires officiels à travers le monde. Ils sont équipés pour vous fournir nos machines à torréfier le café et un support dédié."
  />

  <!-- Bayi Kartları Bölümü -->
  <section class="mx-auto -mt-8 max-w-[85rem] px-4 pb-10 sm:px-6 lg:px-8 lg:pb-14">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        dealers.map((dealer) => (
          <DealerCard
            name={dealer.name}
            company={dealer.company}
            phone={dealer.phone}
            email={dealer.email}
            country={dealer.country}
          />
        ))
      }
    </div>
  </section>
</MainLayout>
