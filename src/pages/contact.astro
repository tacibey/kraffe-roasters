---
// Gerekli bileşenleri ve verileri import et
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSection from "@components/sections/misc/ContactSection.astro";
import { SITE } from "@data/constants"; // SITE sabiti kullanılacak
import amirAvatar from "@images/Amir+Montazer.avif"; // Amir'in avatarı import edildi

// Sayfa başlığını Kraffe Roasters'a göre ayarla
const pageTitle: string = `Contact Us | ${SITE.title}`; // SITE.title Kraffe Roasters olmalı

// Canonical URL için hedef domaini kullan
const canonicalUrl = "https://krafferoasters.com/contact"; // Hedef domain
---

<MainLayout
  title={pageTitle}
  lang="en" {/* Dil etiketi eklendi (opsiyonel ama iyi pratik) */}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": canonicalUrl, // Canonical URL kullanıldı
    "url": canonicalUrl, // Canonical URL kullanıldı
    "name": `Contact Kraffe Roasters | Commercial & Industrial Coffee Roasters`, // Sayfa adı güncellendi
    "description": "Get in touch with Kraffe Roasters for inquiries about our commercial and industrial coffee roasting machines, equipment, or services. Request a quote or consultation.", // Meta description güncellendi
    "isPartOf": {
        "@type": "WebSite",
        "url": "https://krafferoasters.com", // Ana site URL'si güncellendi
        "name": SITE.title, // constants.ts'den alınacak
        "description": SITE.description // constants.ts'den alınacak
    },
    "inLanguage": "en-US"
  }}
>
  {/* ContactSection'a amirAvatar verisi prop olarak geçirildi */}
  <ContactSection amirAvatarData={amirAvatar} />
</MainLayout>

<script is:inline>
  // Bu script sadece bu sayfada çalışır ve başka hiçbir yeri etkilemez.
  document.addEventListener('DOMContentLoaded', () => {
    // 1. WhatsApp butonunu (link) oluştur
    const whatsappButton = document.createElement('a');
    
    // Telefon numaranı ve mesajını buraya yaz
    const phoneNumber = '+905335667061';
    const message = 'Hello Kraffe';
    whatsappButton.href = `https://wa.me/${phoneNumber.replace(/\s/g, '')}?text=${encodeURIComponent(message)}`;
    
    whatsappButton.target = '_blank';
    whatsappButton.rel = 'noopener noreferrer';
    whatsappButton.setAttribute('aria-label', 'Contact us on WhatsApp');

    // 2. Butonu stillendir (cookie ikonu gibi)
    whatsappButton.style.position = 'fixed';
    whatsappButton.style.bottom = '20px'; // Cookie ikonuyla aynı hizada
    whatsappButton.style.right = '80px';  // Cookie ikonunun solunda (20px + 10px boşluk + 50px ikon genişliği)
    whatsappButton.style.width = '50px';
    whatsappButton.style.height = '50px';
    whatsappButton.style.backgroundColor = '#25D366'; // WhatsApp yeşili
    whatsappButton.style.borderRadius = '50%';
    whatsappButton.style.display = 'flex';
    whatsappButton.style.alignItems = 'center';
    whatsappButton.style.justifyContent = 'center';
    whatsappButton.style.boxShadow = '0 4px 14px rgba(0,0,0,0.2)';
    whatsappButton.style.zIndex = '9998'; // Cookie ikonundan bir tık altta
    whatsappButton.style.transition = 'transform 0.2s ease-in-out';

    // Üzerine gelince hafifçe büyüsün
    whatsappButton.onmouseover = () => { whatsappButton.style.transform = 'scale(1.1)'; };
    whatsappButton.onmouseout = () => { whatsappButton.style.transform = 'scale(1)'; };

    // 3. İçine WhatsApp SVG ikonunu ekle
    whatsappButton.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="white">
        <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.894 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.886-.001 2.267.655 4.398 1.908 6.161l-1.317 4.816 4.919-1.295z"/>
      </svg>
    `;

    // 4. Oluşturduğun butonu sayfaya ekle
    document.body.appendChild(whatsappButton);
  });
</script>
