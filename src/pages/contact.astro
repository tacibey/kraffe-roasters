---
// src/pages/contact.astro

// Gerekli bileşenleri ve verileri import et
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSection from "@components/sections/misc/ContactSection.astro";
import { SITE } from "@data/constants"; // SITE sabiti kullanılacak
import amirAvatar from "@images/Amir+Montazer.avif"; // Amir'in avatarı import edildi
import Icon from "@components/ui/icons/Icon.astro"; // İkon bileşeni import edildi

// Sayfa başlığını Kraffe Roasters'a göre ayarla
const pageTitle: string = `Contact Us | ${SITE.title}`; // SITE.title Kraffe Roasters olmalı

// Canonical URL için hedef domaini kullan
const canonicalUrl = "https://krafferoasters.com/contact"; // Hedef domain
---

<MainLayout
  title={pageTitle}
  lang="en" {/* Dil etiketi eklendi (opsiyonel ama iyi pratik) */}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": canonicalUrl, // Canonical URL kullanıldı
    "url": canonicalUrl, // Canonical URL kullanıldı
    "name": `Contact Kraffe Roasters | Commercial & Industrial Coffee Roasters`, // Sayfa adı güncellendi
    "description": "Get in touch with Kraffe Roasters for inquiries about our commercial and industrial coffee roasting machines, equipment, or services. Request a quote or consultation.", // Meta description güncellendi
    "isPartOf": {
        "@type": "WebSite",
        "url": "https://krafferoasters.com", // Ana site URL'si güncellendi
        "name": SITE.title, // constants.ts'den alınacak
        "description": SITE.description // constants.ts'den alınacak
    },
    "inLanguage": "en-US"
  }}
>
  {/* ContactSection'a amirAvatar verisi prop olarak geçirildi */}
  <ContactSection amirAvatarData={amirAvatar} />

  <!-- YENİ EKLENEN BÖLÜM BAŞLANGICI -->
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="rounded-lg bg-white p-6 text-center shadow-lg dark:bg-neutral-700">
      <h2 class="text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-100">
        Looking for a Local Partner?
      </h2>
      <p class="mt-3 text-lg text-neutral-600 dark:text-neutral-300">
        Want to get in contact with a local dealer? Visit our dealers page to find an authorized reseller near you.
      </p>
      <a href="/dealers" class="mt-6 inline-flex items-center justify-center gap-x-2 rounded-lg border border-transparent bg-orange-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-orange-600 disabled:pointer-events-none disabled:opacity-50">
        Find a Dealer
        <Icon name="arrowRightStatic" class="h-4 w-4" />
      </a>
    </div>
  </section>
  <!-- YENİ EKLENEN BÖLÜM SONU -->

</MainLayout>

<script is:inline>
  // Mevcut scriptinizde hiçbir değişiklik yapılmadı.
  document.addEventListener('DOMContentLoaded', () => {
    const phoneNumber = '+905335667061';
    const whatsappMessage = 'Hello Kraffe';
    const buttonContainer = document.createElement('div');
    buttonContainer.style.position = 'fixed';
    buttonContainer.style.bottom = '20px';
    buttonContainer.style.left = '50%';
    buttonContainer.style.transform = 'translateX(-50%)';
    buttonContainer.style.zIndex = '9998';
    buttonContainer.style.display = 'flex';
    buttonContainer.style.gap = '12px';
    const callButton = document.createElement('a');
    callButton.href = `tel:${phoneNumber.replace(/\s/g, '')}`;
    callButton.setAttribute('aria-label', 'Call Us');
    callButton.style.width = '50px';
    callButton.style.height = '50px';
    callButton.style.backgroundColor = '#3B82F6';
    callButton.style.borderRadius = '50%';
    callButton.style.display = 'flex';
    callButton.style.alignItems = 'center';
    callButton.style.justifyContent = 'center';
    callButton.style.boxShadow = '0 4px 14px rgba(0,0,0,0.2)';
    callButton.style.transition = 'transform 0.2s ease-in-out';
    callButton.onmouseover = () => { callButton.style.transform = 'scale(1.1)'; };
    callButton.onmouseout = () => { callButton.style.transform = 'scale(1)'; };
    callButton.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="white">
        <path d="M6.62 10.79a15.5 15.5 0 0 0 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.24.2 2.45.57 3.57.11.35.02.74-.25 1.02l-2.2 2.2z"></path>
      </svg>
    `;
    const whatsappButton = document.createElement('a');
    whatsappButton.href = `https://wa.me/${phoneNumber.replace(/\s/g, '')}?text=${encodeURIComponent(whatsappMessage)}`;
    whatsappButton.target = '_blank';
    whatsappButton.rel = 'noopener noreferrer';
    whatsappButton.setAttribute('aria-label', 'Contact us on WhatsApp');
    whatsappButton.style.width = '50px';
    whatsappButton.style.height = '50px';
    whatsappButton.style.backgroundColor = '#25D366';
    whatsappButton.style.borderRadius = '50%';
    whatsappButton.style.display = 'flex';
    whatsappButton.style.alignItems = 'center';
    whatsappButton.style.justifyContent = 'center';
    whatsappButton.style.boxShadow = '0 4px 14px rgba(0,0,0,0.2)';
    whatsappButton.style.transition = 'transform 0.2s ease-in-out';
    whatsappButton.onmouseover = () => { whatsappButton.style.transform = 'scale(1.1)'; };
    whatsappButton.onmouseout = () => { whatsappButton.style.transform = 'scale(1)'; };
    whatsappButton.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="white">
        <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.894 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.886-.001 2.267.655 4.398 1.908 6.161l-1.317 4.816 4.919-1.295z"/>
      </svg>
    `;
    buttonContainer.appendChild(callButton);
    buttonContainer.appendChild(whatsappButton);
    document.body.appendChild(buttonContainer);
  });
</script>
