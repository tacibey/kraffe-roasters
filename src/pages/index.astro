---
// src/pages/index.astro (Final Version with Advanced Schema)

// Gerekli bileşenleri ve verileri import et
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import FeaturesGeneral from "@components/sections/features/FeaturesGeneral.astro";
import FeaturesNavs from "@components/sections/features/FeaturesNavs.astro";
import TestimonialsSection from "@components/sections/testimonials/TestimonialsSection.astro";
import PricingSection from "@components/sections/pricing/PricingSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";

// Görsel importları
import heroImage from "@images/hero-kraffe.avif";
import thermalControlImage from "@images/features5.avif";
import precisionSystemImage from "@images/sample-coffee-roaster.webp";
import smartIntegrationImage from "@images/kf2.avif";
import amirAvatar from "@images/Amir+Montazer.avif";
import logoForSchema from "@images/kraffe-logo.png"; // Schema için logo importu

// Veri dosyalarını import et
import faqsData from "@data/faqs.json";
import features from "@data/features.json";
import pricing from "@data/pricing.json";
import { SITE, OG } from "@data/constants"; // SITE ve OG import edildi
import { getImage } from "astro:assets";

const avatarSrcs: Array<string> = [
  "https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
];

// === SEO ve SCHEMA İÇİN DEĞİŞKENLER ===
const pageTitle = SITE.title;
const metaDescription = SITE.description;

// Logo ve sosyal medya görselinin tam URL'sini alalım
const logoImage = await getImage({ src: logoForSchema, format: 'png' });
const socialImage = await getImage({ src: OG.image, width: 1200, height: 600, format: 'png' });
const logoUrl = new URL(logoImage.src, Astro.site).href;
const socialImageUrl = new URL(socialImage.src, Astro.site).href;


// JSON verisinden FAQPage şeması için `mainEntity` oluşturma
const faqEntities = faqsData.faqs.map(faq => ({
  "@type": "Question",
  "name": faq.question,
  "acceptedAnswer": {
    "@type": "Answer",
    "text": faq.answer
  }
}));

// Gelişmiş Schema.org yapısı
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": "Kraffe Roasters",
      "url": SITE.url,
      "logo": logoUrl,
      "sameAs": [
        "https://www.facebook.com/krafferoasters",
        "https://www.instagram.com/krafferoasters/"
        // Varsa diğer sosyal medya linkleri eklenebilir
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+90-XXX-XXX-XXXX", // Telefon numaranızı ekleyin
        "contactType": "customer service"
      }
    },
    {
      "@type": "WebSite",
      "url": SITE.url,
      "name": SITE.title,
      "description": SITE.description,
      "publisher": {
        "@type": "Organization",
        "name": "Kraffe Roasters",
        "logo": {
          "@type": "ImageObject",
          "url": logoUrl
        }
      }
    },
    {
      "@type": "CollectionPage",
      "name": "Kraffe Roasters - Commercial & Industrial Coffee Roasting Machines",
      "url": SITE.url,
      "description": metaDescription,
      "image": socialImageUrl,
      "mainEntity": {
        "@type": "FAQPage",
        "mainEntity": faqEntities
      }
    }
  ]
};
---

<MainLayout
  title={pageTitle}
  meta={metaDescription}
  structuredData={structuredData}
>
  <HeroSection
    title=`Master the Art of Roasting: <span class="text-yellow-500 dark:text-yellow-400">KRAFFE Commercial Coffee Roasting Machines</span>`
    subTitle="Achieve precision, durability, and consistency with KRAFFE industrial coffee roasters—designed for professionals and backed by lifetime support."
    primaryBtn="Explore Our Machines"
    primaryBtnURL="/products"
    secondaryBtn="Request a Quote"
    secondaryBtnURL="/contact"
    withReview={true}
    avatars={avatarSrcs}
    rating=`<span class="font-bold">4.8</span> / 5`
    starCount={4}
    reviews=`Trusted by <span class="font-bold">Roasteries</span> Worldwide`
    src={heroImage}
    alt="Detailed view of a commercial Kraffe industrial coffee roasting machine"
  />

  <FeaturesGeneral
    title="Crafted for Roasting Perfection"
    subTitle="KRAFFE ROASTERS expertly engineered to deliver exceptional control, consistency between batches, and efficiency, allowing you to fully unlock the potential of every bean."
    features={features}
  />

  <FeaturesNavs
    title=`Inside the KRAFFE ROASTERS: <span class="text-yellow-500 dark:text-yellow-400">Where Precision Meets Power</span>`
     tabs={[
       {
         heading: "Roast with Confidence—No Matter the Conditions",
         content:
           "Take full control of heat transfer with KRAFFE’s advanced thermal control system, 3mm precision thermocouples, and improved heat insulation, ensuring consistent performance in any environment.",
         svg: "dashboard",
         src: thermalControlImage,
         alt: "Close-up view of Kraffe Roaster's double-walled drum insulation",
         first: true,
       },
       {
         heading: "Precision Roasting System",
         content:
           "Roasting to Perfection. Achieve flawless results with KRAFFE’s modulated premix burner, precise airflow, and sensitive drum speed controls for perfect, consistent roasts every time.",
         svg: "dashboard",
         src: precisionSystemImage,
         alt: "Detailed shot of Kraffe Roaster's precision burner system",
         second: true,
       },
       {
         heading: "Smart Integration for Your Roastery",
         content:
           "Work with commonly used software like Cropster and Artisan, eliminating the need for unnecessary software while ensuring customizable control and precise roasting performance.",
         svg: "dashboard",
         src: smartIntegrationImage,
         alt: "Screenshot showing Kraffe Roaster software integration with Cropster/Artisan",
       },
     ]}
  />

  <TestimonialsSection
    title="Trusted by Professional Roasters"
    subTitle="Hear why leading roasteries choose KRAFFE ROASTERS for quality, consistency, and support."
    testimonials={[
       {
         content:
           "The machine is incredibly user-friendly and delivers consistent results every time. The roasting process is efficient and precise, allowing me to achieve the perfect roast for my coffee beans.",
         author: "Amir Montazer",
         role: "Etude Coffee Co.",
         avatarSrc: amirAvatar,
         avatarAlt: "Portrait of Amir Montazer"
       },
     ]}
    statistics={[
       {
         count: "100% Quality Assurance",
         description:
           "Every machine is thoroughly tested for quality control before shipment to ensure top-tier performance.",
       },
       {
         count: "Solution-Oriented Design",
         description:
           "A flexible approach tailored to meet the unique needs of your roastery.",
       },
       {
         count: "User Friendly",
         description:
           "Designed for a smooth experience at every stage—simple setup, intuitive operation, and effortless maintenance.",
       },
       {
         count: "7/24 Lifetime Support",
         description:
           "Dedicated lifetime support from our solution-oriented team, with a fast response whenever you need assistance.",
       },
     ]}
  />

  <PricingSection pricing={pricing} />

  <FAQ title="Frequently<br />Asked Questions" faqs={faqsData} />

  <HeroSectionAlt
    title="Let's Design Your Machine"
    subTitle="Contact us and our experts will study best fitting KRAFFE model with you."
    url="/contact"
    btnTitle="Contact Us"
  />
</MainLayout>
