---
// src/pages/contact-2.astro

import MainLayout from "../../layouts/MainLayout.astro";
import ContactSection2 from "../components/sections/misc/ContactSection2.astro";
import { SITE } from "@data/constants";

// Sayfa başlığını ve meta açıklamasını belirleyebilirsiniz
const title = `Contact Us | ${SITE.title}`;
const meta = {
  description: "Get a quote for Kraffe commercial coffee roasters. Fill out the form and we'll get back to you in 1-2 business days.",
  // Gerekirse diğer meta etiketlerini ekleyebilirsiniz
};
---

<MainLayout title={title} meta={meta}>
  <ContactSection2 />
</MainLayout>
