---
// src/components/ui/Breadcrumbs.astro
interface Props {
  items: {
    label: string;
    href: string;
  }[];
}

const { items } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.label,
    "item": `${Astro.site?.origin}${item.href}`
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<nav aria-label="Breadcrumb" class="mx-auto w-full max-w-[85rem] px-4 sm:px-6 lg:px-8 pt-4">
  <ol class="flex items-center whitespace-nowrap" aria-label="Breadcrumb">
    <li class="inline-flex items-center">
      <a class="flex items-center text-sm text-gray-500 hover:text-orange-600 focus:outline-none focus:text-orange-600 dark:text-neutral-500 dark:hover:text-orange-500 dark:focus:text-orange-500" href="/">
        <svg class="flex-shrink-0 me-3 size-4" xmlns="http://www.w.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Home
      </a>
      <svg class="flex-shrink-0 mx-2 overflow-visible size-4 text-gray-400 dark:text-neutral-600" xmlns="http://www.w.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </li>
    
    {items.map((item, index) => (
      <li class="inline-flex items-center">
        {index === items.length - 1 ? (
          <span class="flex items-center text-sm font-semibold text-gray-800 truncate dark:text-neutral-200" aria-current="page">
            {item.label}
          </span>
        ) : (
          <>
            <a class="flex items-center text-sm text-gray-500 hover:text-orange-600 focus:outline-none focus:text-orange-600 dark:text-neutral-500 dark:hover:text-orange-500 dark:focus:text-orange-500" href={item.href}>
              {item.label}
            </a>
            <svg class="flex-shrink-0 mx-2 overflow-visible size-4 text-gray-400 dark:text-neutral-600" xmlns="http://www.w.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </>
        )}
      </li>
    ))}
  </ol>
</nav>
