---
// Gerekli bileşenleri ve resimleri import et
import { Image } from "astro:assets";
import AuthBtn from "@components/ui/buttons/AuthBtn.astro";
import ContactIconBlock from "@components/ui/blocks/ContactIconBlock.astro";
import Icon from "@components/ui/icons/Icon.astro";
import ReviewComponent from "@components/ui/blocks/ReviewComponent.astro";
import kraffeContact from "@images/kraffe-contact.avif";
import type { ImageMetadata } from 'astro';

// Prop Tanımı
interface Props {
    amirAvatarData?: ImageMetadata;
}
const { amirAvatarData } = Astro.props;

// Review bölümü için avatar kaynakları
const avatarSrcs: Array<string> = [
  "https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
];

// Sabit metinler
const title: string = "👋 Meet your new roasting machine";
const subTitle: string = `<span class="text-orange-600 dark:text-orange-400">⤹ Fill out our form</span> to unlock your coffee's full potential`;
const formTitle: string = "Get a quote now →";
const formSubTitle: string = "We'll get back to you in 1-2 business days.";

const officeHeading: string = "Our Office";
const officeContent: string = "KRAFFE ROASTERS";
const officeAddress: string = "Adalet, Manas Blv. No:39, Folkart Towers A Kule, Kat:34, D:3408, 35530 Bayraklı/İzmir";

const emailHeading: string = "Contact us by email";
const emailContent: string = "Prefer the written word? Drop us an email at";
const emailLinkTitle: string = "info@krafferoasters.com";
const emailLinkURL: string = "mailto:info@krafferoasters.com";

const phoneHeading: string = "Call us";
const phoneContent: string = "Our lines are open during business hours at";
const phoneLinkTitle: string = "+90 555 123 45 67"; // KENDİ NUMARANLA DEĞİŞTİR
const phoneLinkURL: string = "tel:+905551234567"; // KENDİ NUMARANLA DEĞİŞTİR

const rating: string = `<span class="font-bold">4.8</span> / 5`;
const starCount: number = 4;
const reviews: string = `Trusted by <span class="font-bold">Roasteries</span> Worldwide`;

const formsparkFormId = "la0JBXKn3";
// === BOTPOISON PUBLIC KEY ===
const botpoisonPublicKey = "pk_237e0502-663f-4b6c-ab78-5a125646b975";
// === /BOTPOISON PUBLIC KEY ===

const productOptions = [
  "Dimi - Half kg batch capacity", "Primi - 1 kg batch capacity",
  "KRF-03", "KRF-06", "KRF-12", "KRF-15", "KRF-20",
  "KRF-30", "KRF-60", "KRF-120", "KRF-180", "KRF-240", "Equipment"
];

const allCountries = [
  "Afghanistan", "Albania", "Algeria", "Andorra", "Angola", "Antigua and Barbuda", "Argentina", "Armenia", "Australia", "Austria",
  "Azerbaijan", "Bahamas", "Bahrain", "Bangladesh", "Barbados", "Belarus", "Belgium", "Belize", "Benin", "Bhutan",
  "Bolivia", "Bosnia and Herzegovina", "Botswana", "Brazil", "Brunei", "Bulgaria", "Burkina Faso", "Burundi", "Cabo Verde", "Cambodia",
  "Cameroon", "Canada", "Central African Republic", "Chad", "Chile", "China", "Colombia", "Comoros", "Congo (Brazzaville)", "Congo (Kinshasa)",
  "Costa Rica", "Croatia", "Cuba", "Cyprus", "Czechia", "Denmark", "Djibouti", "Dominica", "Dominican Republic", "East Timor (Timor-Leste)",
  "Ecuador", "Egypt", "El Salvador", "Equatorial Guinea", "Eritrea", "Estonia", "Eswatini", "Ethiopia", "Fiji", "Finland",
  "France", "Gabon", "Gambia", "Georgia", "Germany", "Ghana", "Greece", "Grenada", "Guatemala", "Guinea",
  "Guinea-Bissau", "Guyana", "Haiti", "Honduras", "Hungary", "Iceland", "India", "Indonesia", "Iran", "Iraq",
  "Ireland", "Israel", "Italy", "Ivory Coast", "Jamaica", "Japan", "Jordan", "Kazakhstan", "Kenya", "Kiribati",
  "Kosovo", "Kuwait", "Kyrgyzstan", "Laos", "Latvia", "Lebanon", "Lesotho", "Liberia", "Libya", "Liechtenstein",
  "Lithuania", "Luxembourg", "Madagascar", "Malawi", "Malaysia", "Maldives", "Mali", "Malta", "Marshall Islands", "Mauritania",
  "Mauritius", "Mexico", "Micronesia", "Moldova", "Monaco", "Mongolia", "Montenegro", "Morocco", "Mozambique", "Myanmar (Burma)",
  "Namibia", "Nauru", "Nepal", "Netherlands", "New Zealand", "Nicaragua", "Niger", "Nigeria", "North Korea", "North Macedonia",
  "Norway", "Oman", "Pakistan", "Palau", "Palestine", "Panama", "Papua New Guinea", "Paraguay", "Peru", "Philippines",
  "Poland", "Portugal", "Qatar", "Romania", "Russia", "Rwanda", "Saint Kitts and Nevis", "Saint Lucia", "Saint Vincent and the Grenadines", "Samoa",
  "San Marino", "Sao Tome and Principe", "Saudi Arabia", "Senegal", "Serbia", "Seychelles", "Sierra Leone", "Singapore", "Slovakia", "Slovenia",
  "Solomon Islands", "Somalia", "South Africa", "South Korea", "South Sudan", "Spain", "Sri Lanka", "Sudan", "Suriname", "Sweden",
  "Switzerland", "Syria", "Taiwan", "Tajikian", "Tanzania", "Thailand", "Togo", "Tonga", "Trinidad and Tobago", "Tunisia",
  "Turkiye", "Turkmenistan", "Tuvalu", "Uganda", "Ukraine", "United Arab Emirates", "United Kingdom", "United States", "Uruguay", "Uzbekistan",
  "Vanuatu", "Vatican City", "Venezuela", "Vietnam", "Yemen", "Zambia", "Zimbabwe", "Other"
].sort((a, b) => {
  if (a === "Other") return 1;
  if (b === "Other") return -1;
  return a.localeCompare(b);
});

const inputBaseClass = "block w-full rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-700 placeholder:text-neutral-500 focus:border-neutral-200 focus:outline-hidden focus:ring-3 focus:ring-neutral-400 disabled:pointer-events-none disabled:opacity-50 dark:border-neutral-600 dark:bg-neutral-700/30 dark:text-neutral-300 dark:placeholder:text-neutral-400 dark:focus:ring-1";
---

{/* === BOTPOISON BROWSER SCRIPT'İ (SAYFANIN BAŞINA YAKIN OLMASI İYİDİR) === */}
{botpoisonPublicKey && (
  <script src="https://unpkg.com/@botpoison/browser" async defer></script>
)}
{/* === /BOTPOISON BROWSER SCRIPT'İ === */}

<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
  <div class="mx-auto max-w-2xl lg:max-w-5xl">
    <div class="text-center">
      <h1 class="text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight">
        {title}
      </h1>
      <p class="mt-1 text-pretty text-lg text-neutral-600 dark:text-neutral-400" set:html={subTitle}>
      </p>
       <div class="mt-8 mx-auto max-w-[1500px] px-4 sm:px-6">
        <Image 
          src={kraffeContact} 
          alt="Contact Kraffe Roasters for inquiries" 
          class="w-full h-auto object-cover rounded-xl aspect-[1500/700]"
          loading="lazy"
          widths={[600, 900, 1200, 1500]}
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 90vw, 1500px"
        />
      </div>
    </div>

    <div class={`grid items-start gap-6 lg:grid-cols-2 lg:gap-16 ${amirAvatarData ? 'mt-12 lg:mt-16' : 'mt-12 lg:mt-16'}`}>
      <div class="flex flex-col rounded-xl border border-neutral-200 bg-neutral-100 p-4 shadow-sm dark:border-neutral-700 dark:bg-neutral-800 sm:p-6 lg:p-8">
        <h2 class="mb-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200">
          {formTitle}
        </h2>

        {/* === FORMSPARK FORM GÜNCELLENDİ (BOTPOISON İLE) === */}
        <form
          id="contact-form-kraffe" {/* Event listener için ID eklendi */}
          action={`https://submit-form.com/${formsparkFormId}`}
          method="POST"
          data-botpoison-public-key={botpoisonPublicKey} {/* Botpoison public key eklendi */}
        >
          <input type="text" name="_honeypot" style="display: none;" tabindex="-1" autocomplete="off"/>
          <input type="hidden" name="_redirect" value="https://krafferoasters.com/thanks" />

          <div class="grid gap-4">
            <div>
              <label for="contact-name" class="sr-only">Name</label>
              <input type="text" id="contact-name" name="name" class={inputBaseClass} placeholder="Name" required />
            </div>
            <div>
              <label for="contact-company" class="sr-only">Company</label>
              <input type="text" id="contact-company" name="company" class={inputBaseClass} placeholder="Company" />
            </div>
            <div>
              <label for="contact-email" class="sr-only">Email</label>
              <input type="email" id="contact-email" name="email" class={inputBaseClass} placeholder="Email" required autocomplete="email"/>
            </div>
            <div>
              <label for="contact-phone-number" class="sr-only">Phone Number</label>
              <div class="flex rounded-lg shadow-sm">
                <div class="px-3 inline-flex items-center min-w-fit rounded-s-lg border border-e-0 border-neutral-200 bg-neutral-200 dark:bg-neutral-700 dark:border-neutral-600">
                  <span class="text-sm text-neutral-500 dark:text-neutral-400">+</span>
                </div>
                <input
                  type="text"
                  id="contact-country-code"
                  name="countryCode"
                  class="py-3 px-4 block w-[80px] border-neutral-200 -ms-px text-sm focus:z-10 focus:border-orange-500 focus:ring-orange-500 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-700/30 dark:border-neutral-600 dark:text-neutral-300 dark:focus:ring-orange-600 dark:placeholder-neutral-500"
                  placeholder="Code"
                  aria-label="Country code"
                />
                <input
                  type="tel"
                  id="contact-phone-number"
                  name="phone"
                  class={`${inputBaseClass} rounded-s-none`}
                  placeholder="Phone Number"
                  aria-label="Phone number"
                />
              </div>
            </div>
            <div>
              <label for="contact-country" class="sr-only">Select Country</label>
              <select id="contact-country" name="country" class={inputBaseClass + " cursor-pointer"}>
                <option value="" disabled selected>Select Country</option>
                {allCountries.map(country => (
                  <option value={country}>{country}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="contact-product" class="sr-only">Select Product</label>
              <select id="contact-product" name="product" class={inputBaseClass + " cursor-pointer"}>
                <option value="" disabled selected>Select Product</option>
                {productOptions.map(option => (
                  <option value={option}>{option}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="contact-details" class="sr-only">Details</label>
              <textarea id="contact-details" name="message" rows="4" class={inputBaseClass} placeholder="Details" required></textarea>
            </div>
            
            {/* reCAPTCHA KALDIRILDI */}
          </div>
          <div class="mt-4 grid">
            {/* Butona ID eklendi */}
            <AuthBtn title="Send Message" type="submit" id="contact-submit-button" />
          </div>
          <div class="mt-3 text-center">
            <p class="text-sm text-neutral-600 dark:text-neutral-400">
              {formSubTitle}
            </p>
          </div>
        </form>
        {/* === /FORMSPARK FORM === */}
      </div>

      <div class="space-y-8">
        {amirAvatarData && (
            <div class="rounded-xl border border-neutral-200 bg-neutral-100 p-4 shadow-sm dark:border-neutral-700 dark:bg-neutral-800 sm:p-6">
                <ReviewComponent amirAvatarData={amirAvatarData} avatars={avatarSrcs} starCount={starCount} rating={rating} reviews={reviews} />
            </div>
        )}
        <div class={`space-y-6 divide-y divide-neutral-200 dark:divide-neutral-700 ${!amirAvatarData ? 'mt-0' : ''}`}>
  {/* Office Block */}
  <div class="pt-6 first:pt-0">
    <ContactIconBlock heading={officeHeading} content={officeContent} isAddressVisible={true} addressContent={officeAddress}>
      <Icon name="mapPin" />
    </ContactIconBlock>
  </div>
  {/* Email Block */}
  <div class="pt-6">
    <ContactIconBlock heading={emailHeading} content={emailContent} isLinkVisible={true} linkTitle={emailLinkTitle} linkURL={emailLinkURL}>
      <Icon name="envelopeOpen" />
    </ContactIconBlock>
  </div>
  {/* Phone Block */}
  <div class="pt-6">
    <ContactIconBlock heading={phoneHeading} content={phoneContent} isLinkVisible={true} linkTitle={phoneLinkTitle} linkURL={phoneLinkURL}>
      <Icon name="phone" />
    </ContactIconBlock>
  </div>
</div>
          <div class="pt-6 first:pt-0">
             <ContactIconBlock heading={phoneHeading} content={phoneContent} isLinkVisible={true} linkTitle={phoneLinkTitle} linkURL={phoneLinkURL}>
               <Icon name="phone" />
             </ContactIconBlock>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{/* reCAPTCHA API Script'i KALDIRILDI */}

{/* === BOTPOISON EVENT LISTENER SCRIPT'İ (İSTEĞE BAĞLI) === */}
{botpoisonPublicKey && (
  <script is:inline>
    const formElement = document.getElementById("contact-form-kraffe");
    const buttonElement = document.getElementById("contact-submit-button");

    if (formElement && buttonElement) {
      formElement.addEventListener("botpoison-challenge-start", function () {
        buttonElement.setAttribute("disabled", "disabled");
        // İsterseniz burada butona bir "loading" class'ı ekleyip metnini değiştirebilirsiniz.
        // buttonElement.textContent = "Sending...";
      });
      formElement.addEventListener("botpoison-challenge-success", function () {
        buttonElement.removeAttribute("disabled");
        // buttonElement.textContent = "Send Message";
      });
      formElement.addEventListener("botpoison-challenge-error", function () {
        buttonElement.removeAttribute("disabled");
        // buttonElement.textContent = "Send Message";
        // İsterseniz burada bir hata mesajı gösterebilirsiniz.
        // alert("An error occurred with spam protection. Please try again.");
      });
    }
  </script>
)}
{/* === /BOTPOISON EVENT LISTENER SCRIPT'İ === */}
