---
// ... (diğer importlar ve değişkenler aynı) ...
// === BOTPOISON PUBLIC KEY ===
const botpoisonPublicKey_FR = "pk_237e0502-663f-4b6c-ab78-5a125646b975"; // Aynı key kullanılabilir
// === /BOTPOISON PUBLIC KEY ===
const formsparkFormId_FR = "la0JBXKn3"; // Aynı veya farklı ID
// ... (diğer Fransızca metinler) ...
---

{/* === BOTPOISON BROWSER SCRIPT'İ (SAYFANIN BAŞINA YAKIN OLMASI İYİDİR) === */}
{botpoisonPublicKey_FR && (
  <script src="https://unpkg.com/@botpoison/browser" async defer></script>
)}
{/* === /BOTPOISON BROWSER SCRIPT'İ === */}

<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
  {/* ... (sayfanın üst kısmı aynı) ... */}
    <div class="mt-8 grid items-start gap-6 lg:mt-10 lg:grid-cols-2 lg:gap-16">
      <div class="flex flex-col rounded-xl border border-neutral-200 bg-neutral-100 p-4 shadow-sm dark:border-neutral-700 dark:bg-neutral-800 sm:p-6 lg:p-8">
        {/* ... (form başlığı aynı) ... */}

        <form
          id="contact-form-kraffe-fr" {/* Farklı ID */}
          action={`https://submit-form.com/${formsparkFormId_FR}`}
          method="POST"
          data-botpoison-public-key={botpoisonPublicKey_FR}
        >
          <input type="text" name="_honeypot" style="display: none;" tabindex="-1" autocomplete="off"/>
          <input type="hidden" name="_redirect" value="https://krafferoasters.com/fr/thanks" />

          <div class="grid gap-4">
            {/* ... (Fransızca form alanları aynı, ID'ler -fr ile) ... */}
             <div>
              <label for="contact-phone-number-fr" class="sr-only">Numéro de téléphone</label>
              <div class="flex rounded-lg shadow-sm">
                <div class="px-3 inline-flex items-center min-w-fit rounded-s-lg border border-e-0 border-neutral-200 bg-neutral-200 dark:bg-neutral-700 dark:border-neutral-600">
                  <span class="text-sm text-neutral-500 dark:text-neutral-400">+</span>
                </div>
                <input
                  type="text"
                  id="contact-country-code-fr"
                  name="countryCode"
                  class="py-3 px-4 block w-[80px] border-neutral-200 -ms-px text-sm focus:z-10 focus:border-orange-500 focus:ring-orange-500 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-700/30 dark:border-neutral-600 dark:text-neutral-300 dark:focus:ring-orange-600 dark:placeholder-neutral-500"
                  placeholder="Indicatif" 
                  aria-label="Indicatif pays"
                />
                <input
                  type="tel"
                  id="contact-phone-number-fr"
                  name="phone"
                  class={`${inputBaseClass} rounded-s-none`}
                  placeholder="Numéro de téléphone"
                  aria-label="Numéro de téléphone"
                />
              </div>
            </div>
            {/* ... (diğer form alanları) ... */}
            {/* reCAPTCHA alanı zaten silinmişti */}
          </div>
          <div class="mt-4 grid">
            <AuthBtn title="Envoyer le message" type="submit" id="contact-submit-button-fr" /> {/* Farklı ID */}
          </div>
          {/* ... (form altı metni) ... */}
        </form>
      </div>
      {/* ... (sağ taraf aynı) ... */}
    </div>
  {/* ... (sayfanın kalanı aynı) ... */}
</section>

{/* reCAPTCHA script'i zaten silinmişti */}

{/* === BOTPOISON EVENT LISTENER SCRIPT'İ (FRANSIZCA - İSTEĞE BAĞLI) === */}
{botpoisonPublicKey_FR && (
  <script is:inline>
    const formElement_fr = document.getElementById("contact-form-kraffe-fr");
    const buttonElement_fr = document.getElementById("contact-submit-button-fr");

    if (formElement_fr && buttonElement_fr) {
      formElement_fr.addEventListener("botpoison-challenge-start", function () {
        buttonElement_fr.setAttribute("disabled", "disabled");
      });
      formElement_fr.addEventListener("botpoison-challenge-success", function () {
        buttonElement_fr.removeAttribute("disabled");
      });
      formElement_fr.addEventListener("botpoison-challenge-error", function () {
        buttonElement_fr.removeAttribute("disabled");
      });
    }
  </script>
)}
{/* === /BOTPOISON EVENT LISTENER SCRIPT'İ === */}
