---
// src/components/sections/fr/ContactSection_fr.astro

// Gerekli bileşenleri ve resimleri import et
import { Image } from "astro:assets";
import type { ImageMetadata } from 'astro';
import AuthBtn from "@components/ui/buttons/AuthBtn.astro";
import ContactIconBlock from "@components/ui/blocks/ContactIconBlock.astro";
import Icon from "@components/ui/icons/Icon.astro";
import ReviewComponent from "@components/ui/blocks/ReviewComponent.astro";
import kraffeContact from "@images/kraffe-contact.avif"; // İngilizce dosyadaki gibi

interface Props {
    amirAvatarData: ImageMetadata; // Bu prop /fr/contact.astro'dan geliyor
}
const { amirAvatarData } = Astro.props;

// Review bölümü için avatar kaynakları (İngilizce ile aynı)
const groupAvatarSrcs: Array<string> = [
  "https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
];

// Sabit metinler (Fransızca)
const title: string = "👋 Découvrez votre nouvelle machine à torréfier"; // Örnek çeviri
const subTitle: string = "⤹ Remplissez notre formulaire pour libérer tout le potentiel de vos grains de café"; // Örnek çeviri
const formTitle: string = "Obtenez un devis maintenant →"; // Örnek çeviri
const formSubTitleItalic: string = `(<span class="text-orange-500 dark:text-orange-400">2</span>/10 places restantes)`; // Bu zaten vardı
const formResponseTime: string = "Nous vous répondrons dans un délai de 1 à 2 jours ouvrables.";

// Office verileri (Fransızca)
const officeHeading: string = "Notre Bureau";
const officeContent: string = "KRAFFE ROASTERS";
const officeAddress: string = "Adalet, Manas Blv. No:39, Folkart Towers A Kule, Kat:34, D:3408, 35530 Bayraklı/İzmir"; // Adres çevirisi size kalmış

// Email verileri (Fransızca)
const emailHeading: string = "Contactez-nous par e-mail";
const emailContent: string = "Vous préférez l'écrit ? Envoyez-nous un e-mail à";
const emailLinkTitle: string = "info@krafferoasters.com"; // Genellikle değişmez
const emailLinkURL: string = "mailto:info@krafferoasters.com"; // Genellikle değişmez

// Review verileri (Fransızca)
const rating: string = `<span class="font-bold">4.8</span> / 5`;
const starCount: number = 4;
const reviews: string = `Approuvé par les <span class="font-bold">Torréfacteurs</span> du monde entier`;

const staticFormsApiKey = "sf_323gg5f098n8e9d9ch167dmh";
const recaptchaSiteKey = "6LeLrxwrAAAAABfZl7OIP3Yv0ibik2SANXaLixp6";
const redirectUrl = "https://krafferoasters.com/fr"; // Fransızca yönlendirme

// Ürün listesi (Fransızca)
const productOptions_fr = [ // _fr son eki eklendi
  "Dimi - Capacité de lot d'un demi-kg", "Primi - Capacité de lot de 1 kg",
  "KRF-03", "KRF-06", "KRF-12", "KRF-15", "KRF-20", "KRF-30",
  "KRF-60", "KRF-120", "KRF-180", "KRF-240", "Équipement" // Equipment -> Équipement
];

// === ÜLKE LİSTESİ (İNGİLİZCE İSİMLERLE) ===
const allCountries = [ // İngilizce ContactSection.astro'daki listenin aynısı
  "Afghanistan", "Albania", "Algeria", "Andorra", "Angola", "Antigua and Barbuda", "Argentina", "Armenia", "Australia", "Austria", "Azerbaijan",
  "Bahamas", "Bahrain", "Bangladesh", "Barbados", "Belarus", "Belgium", "Belize", "Benin", "Bhutan", "Bolivia", "Bosnia and Herzegovina", "Botswana", "Brazil", "Brunei", "Bulgaria", "Burkina Faso", "Burundi",
  "Cabo Verde", "Cambodia", "Cameroon", "Canada", "Central African Republic", "Chad", "Chile", "China", "Colombia", "Comoros", "Congo, Democratic Republic of the", "Congo, Republic of the", "Costa Rica", "Cote d'Ivoire", "Croatia", "Cuba", "Cyprus", "Czech Republic",
  "Denmark", "Djibouti", "Dominica", "Dominican Republic",
  "Ecuador", "Egypt", "El Salvador", "Equatorial Guinea", "Eritrea", "Estonia", "Eswatini", "Ethiopia",
  "Fiji", "Finland", "France", "Gabon", "Gambia", "Georgia", "Germany", "Ghana", "Greece", "Grenada", "Guatemala", "Guinea", "Guinea-Bissau", "Guyana",
  "Haiti", "Honduras", "Hungary",
  "Iceland", "India", "Indonesia", "Iran", "Iraq", "Ireland", "Israel", "Italy",
  "Jamaica", "Japan", "Jordan",
  "Kazakhstan", "Kenya", "Kiribati", "Korea, North", "Korea, South", "Kosovo", "Kuwait", "Kyrgyzstan",
  "Laos", "Latvia", "Lebanon", "Lesotho", "Liberia", "Libya", "Liechtenstein", "Lithuania", "Luxembourg",
  "Madagascar", "Malawi", "Malaysia", "Maldives", "Mali", "Malta", "Marshall Islands", "Mauritania", "Mauritius", "Mexico", "Micronesia", "Moldova", "Monaco", "Mongolia", "Montenegro", "Morocco", "Mozambique", "Myanmar",
  "Namibia", "Nauru", "Nepal", "Netherlands", "New Zealand", "Nicaragua", "Niger", "Nigeria", "North Macedonia", "Norway",
  "Oman",
  "Pakistan", "Palau", "Palestine State", "Panama", "Papua New Guinea", "Paraguay", "Peru", "Philippines", "Poland", "Portugal",
  "Qatar",
  "Romania", "Russia", "Rwanda",
  "Saint Kitts and Nevis", "Saint Lucia", "Saint Vincent and the Grenadines", "Samoa", "San Marino", "Sao Tome and Principe", "Saudi Arabia", "Senegal", "Serbia", "Seychelles", "Sierra Leone", "Singapore", "Slovakia", "Slovenia", "Solomon Islands", "Somalia", "South Africa", "South Sudan", "Spain", "Sri Lanka", "Sudan", "Suriname", "Sweden", "Switzerland", "Syria",
  "Taiwan", "Tajikistan", "Tanzania", "Thailand", "Timor-Leste", "Togo", "Tonga", "Trinidad and Tobago", "Tunisia", "Turkey", "Turkmenistan", "Tuvalu",
  "Uganda", "Ukraine", "United Arab Emirates", "United Kingdom", "United States", "Uruguay", "Uzbekistan",
  "Vanuatu", "Vatican City", "Venezuela", "Vietnam",
  "Yemen",
  "Zambia", "Zimbabwe",
  "Other"
].sort((a, b) => {
    if (a === "Other") return 1;
    if (b === "Other") return -1;
    return a.localeCompare(b); // İngilizceye göre sıralama
});
// === /ÜLKE LİSTESİ ===

const inputBaseClass = "block w-full rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-700 placeholder:text-neutral-500 focus:border-neutral-200 focus:outline-hidden focus:ring-3 focus:ring-neutral-400 disabled:pointer-events-none disabled:opacity-50 dark:border-neutral-600 dark:bg-neutral-700/30 dark:text-neutral-300 dark:placeholder:text-neutral-400 dark:focus:ring-1";
---

<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
  <div class="mx-auto max-w-2xl lg:max-w-5xl">
    <div class="text-center">
      <h1 class="text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight">
        {title}
      </h1>
      <p class="mt-1 text-pretty text-lg text-neutral-600 dark:text-neutral-400">
        {subTitle}
      </p>
      <div class="mt-8 mx-auto max-w-[1500px] px-4 sm:px-6">
        <Image 
          src={kraffeContact} 
          alt="Image de couverture pour contact Kraffe" 
          class="w-full h-auto object-cover rounded-xl aspect-[1500/700]"
          loading="lazy"
          widths={[600, 900, 1200, 1500]}
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 90vw, 1500px"
        />
      </div>
    </div>

    <div class={`grid items-start gap-6 lg:grid-cols-2 lg:gap-16 ${amirAvatarData ? 'mt-12 lg:mt-16' : 'mt-12 lg:mt-16'}`}>
      <div class="flex flex-col rounded-xl border border-neutral-200 bg-neutral-100 p-4 shadow-sm dark:border-neutral-700 dark:bg-neutral-800 sm:p-6 lg:p-8">
        <div class="mb-8 text-center">
            <h2 class="text-xl font-semibold text-neutral-800 dark:text-neutral-200" set:html={formTitle} />
            <p class="mt-1 text-sm italic text-neutral-600 dark:text-neutral-400" set:html={formSubTitleItalic} />
        </div>

        <form action="https://api.staticforms.xyz/submit" method="POST">
          <input type="hidden" name="apiKey" value={staticFormsApiKey} />
          <input type="hidden" name="replyTo" value="@" />
          <input type="text" name="honeypot" style="display: none;" tabindex="-1" autocomplete="off"/>
          <input type="hidden" name="redirectTo" value={redirectUrl} />

          <div class="grid gap-4">
            <div>
              <label for="contact-name-fr" class="sr-only">Nom</label>
              <input type="text" id="contact-name-fr" name="name" class={inputBaseClass} placeholder="Nom" required />
            </div>
            <div>
              <label for="contact-company-fr" class="sr-only">Société</label>
              <input type="text" id="contact-company-fr" name="$company" class={inputBaseClass} placeholder="Société" />
            </div>
            <div>
              <label for="contact-email-fr" class="sr-only">E-mail</label>
              <input type="email" id="contact-email-fr" name="email" class={inputBaseClass} placeholder="E-mail" required autocomplete="email"/>
            </div>
            <div>
              <label for="contact-phone-number-fr" class="sr-only">Numéro de téléphone</label>
              <div class="flex rounded-lg shadow-sm">
                <div class="px-3 inline-flex items-center min-w-fit rounded-s-lg border border-e-0 border-neutral-200 bg-neutral-200 dark:bg-neutral-700 dark:border-neutral-600">
                  <span class="text-sm text-neutral-500 dark:text-neutral-400">+</span>
                </div>
                <input
                  type="text"
                  id="contact-country-code-fr"
                  name="$countryCode"
                  class="py-3 px-4 block w-[80px] border-neutral-200 -ms-px text-sm focus:z-10 focus:border-orange-500 focus:ring-orange-500 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-700/30 dark:border-neutral-600 dark:text-neutral-300 dark:focus:ring-orange-600 dark:placeholder-neutral-500"
                  placeholder="Indicatif" 
                  aria-label="Indicatif pays"
                />
                <input
                  type="tel"
                  id="contact-phone-number-fr"
                  name="phone"
                  class={`${inputBaseClass} rounded-s-none`}
                  placeholder="Numéro de téléphone"
                  aria-label="Numéro de téléphone"
                />
              </div>
            </div>

            {/* ÜLKE SEÇİMİ (İNGİLİZCE İSİMLERLE) */}
            <div>
              <label for="contact-country-fr" class="sr-only">Sélectionnez le pays</label>
              <select id="contact-country-fr" name="$country" class={inputBaseClass + " cursor-pointer"}>
                <option value="" disabled selected>Sélectionnez le pays</option>
                {allCountries.map(country => ( // İngilizce 'allCountries' listesi kullanılıyor
                  <option value={country}>{country}</option>
                ))}
              </select>
            </div>

            <div>
              <label for="contact-product-fr" class="sr-only">Sélectionnez le produit</label>
              <select id="contact-product-fr" name="$product" class={inputBaseClass + " cursor-pointer"}>
                <option value="" disabled selected>Sélectionnez le produit</option>
                {productOptions_fr.map(option => ( // Fransızca ürün listesi
                  <option value={option}>{option}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="contact-details-fr" class="sr-only">Détails</label>
              <textarea id="contact-details-fr" name="message" rows="4" class={inputBaseClass} placeholder="Détails" required></textarea>
            </div>
            <div class="mt-2">
                <div class="g-recaptcha" data-sitekey={recaptchaSiteKey}></div>
            </div>
          </div>
          <div class="mt-4 grid">
            <AuthBtn title="Envoyer le message" />
          </div>
          <div class="mt-3 text-center">
            <p class="text-sm text-neutral-600 dark:text-neutral-400">
              {formResponseTime}
            </p>
          </div>
        </form>
      </div>

      <div class="space-y-8">
        {amirAvatarData && (
            <div class="rounded-xl border border-neutral-200 bg-neutral-100 p-4 shadow-sm dark:border-neutral-700 dark:bg-neutral-800 sm:p-6">
                <ReviewComponent
                testimonialText="Incroyablement convivial et fournit des résultats constants à chaque fois."
                testimonialAuthor="Amir Montazer"
                testimonialRole="Etude Coffee Co."
                testimonialAvatar={amirAvatarData} // Bu prop /fr/contact.astro'dan geliyor
                testimonialAvatarAlt="Portrait d'Amir Montazer"
                avatars={groupAvatarSrcs}
                starCount={starCount}
                rating={rating}
                reviews={reviews}
                />
            </div>
        )}
        <div class={`space-y-6 divide-y divide-neutral-200 dark:divide-neutral-700 ${!amirAvatarData ? 'lg:order-first' : '' }`}> {/* Eğer amirAvatarData yoksa bu blok sola geçsin */}
          <div class="pt-6 first:pt-0">
             <ContactIconBlock heading={officeHeading} content={officeContent} isAddressVisible={true} addressContent={officeAddress}>
               <Icon name="mapPin" />
             </ContactIconBlock>
          </div>
          <div class="pt-6 first:pt-0">
             <ContactIconBlock heading={emailHeading} content={emailContent} isLinkVisible={true} linkTitle={emailLinkTitle} linkURL={emailLinkURL}>
               <Icon name="envelopeOpen" />
             </ContactIconBlock>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="https://www.google.com/recaptcha/api.js" async defer></script>
