---
// src/components/HreflangLinks.astro
const { pathname } = Astro.url;

// Mevcut path'in /fr ile başlayıp başlamadığını kontrol et
const isFrench = pathname.startsWith('/fr');

// /fr/ prefix'ini kaldırarak base path'i bul
const basePath = isFrench ? pathname.substring(3) : pathname;

// Her iki dil için de tam URL'leri oluştur (Astro.site'ı kullanarak)
// Ana sayfa için özel durum: basePath boşsa '/' kullan
const englishUrl = new URL(basePath || '/', Astro.site).href;
const frenchUrl = new URL(`/fr${basePath || '/'}`, Astro.site).href;
---

<link rel="alternate" hreflang="en" href={englishUrl} />
<link rel="alternate" hreflang="fr" href={frenchUrl} />
<link rel="alternate" hreflang="x-default" href={englishUrl} />
