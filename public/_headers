# public/_headers

/*
  Content-Security-Policy:
  'unsafe-inline' ve 'unsafe-eval' güvenlik riskleri oluşturabilir, ancak
  mevcut kütüphaneler (Preline, GTM) için şimdilik gereklidir.
  Google Fonts gibi ek kaynaklar eklerseniz, style-src ve font-src'ye eklemeniz gerekir.
*/
/.*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; form-action 'self' https://submit-form.com; frame-src 'self'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://unpkg.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https://images.unsplash.com https://raw.githubusercontent.com; connect-src 'self'; object-src 'none'; upgrade-insecure-requests; block-all-mixed-content
  Permissions-Policy: interest-cohort=()
  Referrer-Policy: no-referrer-when-downgrade
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Cache-Control: public, max-age=0, must-revalidate
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
